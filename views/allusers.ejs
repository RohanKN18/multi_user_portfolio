<%- include("includes/head.ejs"); %>

<body>
  <%- include("includes/backgroundnoanimation.ejs"); %>

  <div class="users-container">
    <h1 class="page-title">All Users</h1>

    <table class="users-table">
      <thead>
        <tr>
          <th>Username</th>
          <th>Email</th>
          <th>Portfolio</th>
        </tr>
      </thead>

      <tbody>
        <% users.forEach(user => { %>
          <tr>
            <td><%= user.username %></td>
            <td><%= user.email %></td>
            <td>
              <a class="portfolio-link" href="/<%= user.username %>/publicportfolio">
                View Portfolio
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <%- include("includes/jsscript.ejs"); %>
</body>
</html>