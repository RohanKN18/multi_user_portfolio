<%- include("../../includes/head.ejs"); %>

<body>
  <%- include("../../includes/backgroundnoanimation.ejs"); %>

  <form action="/<%= user.username %>/portfolio/editfooter" method="POST" id="editFooterForm">

    <h2>Edit Footer</h2>

    <!-- Contact -->
    <div class="formGroup">
      <label>Email</label>
      <input type="email" name="email" value="<%= footer?.contact?.email || '' %>">
    </div>

    <div class="formGroup">
      <label>Phone</label>
      <input type="text" name="phone" value="<%= footer?.contact?.phone || '' %>">
    </div>

    <!-- Social Links -->
    <h3>Social Links</h3>

    <div id="socialContainer">

      <% if (footer?.socialLinks?.length) { %>
        <% footer.socialLinks.forEach((link, index) => { %>
          <div class="formGroup socialRow">
            <label>Name</label>
            <input type="text" name="socialLinks[<%= index %>][name]" value="<%= link.name || '' %>">

            <label>URL</label>
            <input type="text" name="socialLinks[<%= index %>][url]" value="<%= link.url || '' %>">

            <button type="button" class="removeLinkBtn" onclick="removeRow(this)">✕ Remove</button>
          </div>
        <% }) %>
      <% } else { %>
        <!-- Empty initial row -->
        <div class="formGroup socialRow">
          <label>Name</label>
          <input type="text" name="socialLinks[0][name]" placeholder="GitHub">

          <label>URL</label>
          <input type="text" name="socialLinks[0][url]" placeholder="https://...">

          <button type="button" class="removeLinkBtn" onclick="removeRow(this)">✕ Remove</button>
        </div>
      <% } %>

    </div>

    <button type="button" id="addSocialBtn">+ Add Link</button>

    <!-- Copyright -->
    <div class="formGroup">
      <label>Year</label>
      <input type="number" name="year" value="<%= footer?.copyright?.year || '' %>">
    </div>

    <div class="formGroup">
      <label>Name</label>
      <input type="text" name="name" value="<%= footer?.copyright?.name || '' %>">
    </div>

    <button type="submit">Save Changes</button>

  </form>


  <script>
    // Initialise counter from server-rendered value — EJS runs here correctly
    let linkIndex = <%= (footer && footer.socialLinks && footer.socialLinks.length > 0) ? footer.socialLinks.length : 1 %>;

    document.getElementById("addSocialBtn").addEventListener("click", () => {
      const container = document.getElementById("socialContainer");

      const div = document.createElement("div");
      div.classList.add("formGroup", "socialRow");

      div.innerHTML = `
        <label>Name</label>
        <input type="text" name="socialLinks[${linkIndex}][name]" placeholder="Platform">

        <label>URL</label>
        <input type="text" name="socialLinks[${linkIndex}][url]" placeholder="https://...">

        <button type="button" class="removeLinkBtn" onclick="removeRow(this)">✕ Remove</button>
      `;

      container.appendChild(div);
      linkIndex++;
    });

    function removeRow(btn) {
      const row = btn.closest(".socialRow");
      if (row) row.remove();
      reindex();
    }

    // Keep indices contiguous after a removal so the server parses them correctly
    function reindex() {
      const rows = document.querySelectorAll("#socialContainer .socialRow");
      rows.forEach((row, i) => {
        const inputs = row.querySelectorAll("input");
        inputs[0].name = `socialLinks[${i}][name]`;
        inputs[1].name = `socialLinks[${i}][url]`;
      });
      linkIndex = rows.length;
    }
  </script>

</body>
</html>
