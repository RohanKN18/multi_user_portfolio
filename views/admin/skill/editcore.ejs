<%- include("../../includes/head.ejs"); %>
<body style="padding-top:0%;">
<%- include("../../includes/backgroundnoanimation.ejs"); %>
<div class="formtopicBox">

<form method="POST"
      action="/<%= user.username %>/portfolio/core/<%= selectedSkill.slug %>/<%= selectedTopic._id %>/<%= coreSkill._id %>/edit"
      class="topicForm">

    <h1>Edit Core Skill</h1>

    <input
        type="text"
        name="coreName"
        value="<%= coreSkill.name %>"
        required
    >

    <button type="submit">Save</button>

</form>

</div>

</body>
</html>