<%- include("../../includes/head.ejs"); %>
<body style="padding-top:0%;">
<%- include("../../includes/backgroundnoanimation.ejs"); %>
<div class="formtopicBox">

<form class="topicForm"
      method="POST"
      action="/<%= user.username %>/portfolio/topics/<%= selectedSkill.slug %>/<%= selectedTopic._id %>/addcoreskill">

    <h1>Add Core Skill</h1>

    <input
        type="text"
        name="coreSkill"
        placeholder="Enter core skill..."
        required
    >

    <button type="submit">Add</button>

</form>

</div>

</body>
</html>