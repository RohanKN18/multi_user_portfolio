<div class="loginBox">
  <form class="loginForm" method="POST" action="/login">

    <div id="loginPhotocontainer">
        <div id="loginPhoto"></div>
    </div>

    <!-- Username -->
    <input 
        type="text" 
        name="username" 
        placeholder="Enter Username" 
        required
    >

    <!-- Password -->
    <input 
        type="password" 
        name="password" 
        placeholder="Enter Password" 
        required
    >

    <button type="submit">Login</button>

</form>
</div>